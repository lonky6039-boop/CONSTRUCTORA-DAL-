import React, { useState } from "react";
import Canvas3D from "../components/Canvas3D";

export default function Editor() {
  const [tool, setTool] = useState("muro");

  return (
    <div>
      <h1>CONSTRUCTORA DAL</h1>

      <div style={{ marginBottom: "10px" }}>
        <button onClick={() => setTool("muro")}>Muro</button>
        <button onClick={() => setTool("puerta")}>Puerta</button>
        <button onClick={() => setTool("ventana")}>Ventana</button>
      </div>

      <Canvas3D tool={tool} />
    </div>
  );
}
import React, { useRef, useEffect } from "react";
import * as THREE from "three";

export default function Canvas3D({ tool }) {
  const mountRef = useRef(null);

  useEffect(() => {
    const scene = new THREE.Scene();

    const camera = new THREE.OrthographicCamera(
      window.innerWidth / -100,
      window.innerWidth / 100,
      window.innerHeight / 100,
      window.innerHeight / -100,
      1,
      1000
    );

    camera.position.z = 10;

    const renderer = new THREE.WebGLRenderer();
    renderer.setSize(window.innerWidth, window.innerHeight);
    mountRef.current.appendChild(renderer.domElement);

    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();

    let puntos = [];

    function onClick(event) {
      mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const point = raycaster.ray.origin.clone();

      puntos.push(point);

      if (puntos.length === 2) {
        crearElemento(puntos[0], puntos[1]);
        puntos = [];
      }
    }

    function crearElemento(p1, p2) {
      const length = p1.distanceTo(p2);

      const geometry = new THREE.BoxGeometry(length, 0.2, 0.2);

      let color = 0x888888;

      if (tool === "puerta") color = 0x654321;
      if (tool === "ventana") color = 0x00aaff;

      const material = new THREE.MeshBasicMaterial({ color });

      const mesh = new THREE.Mesh(geometry, material);

      mesh.position.set(
        (p1.x + p2.x) / 2,
        (p1.y + p2.y) / 2,
        0
      );

      mesh.rotation.z = Math.atan2(p2.y - p1.y, p2.x - p1.x);

      scene.add(mesh);
    }

    window.addEventListener("click", onClick);

    const animate = () => {
      requestAnimationFrame(animate);
      renderer.render(scene, camera);
    };

    animate();

    return () => {
      window.removeEventListener("click", onClick);
      mountRef.current.removeChild(renderer.domElement);
    };
  }, [tool]);

  return <div ref={mountRef}></div>;
}
