import React, { useRef, useEffect, useState } from "react";
import * as THREE from "three";

export default function Canvas3D({ tool }) {
  const mountRef = useRef(null);

  const [puntos, setPuntos] = useState([]);
  const [objetos, setObjetos] = useState([]);

  useEffect(() => {
    const scene = new THREE.Scene();

    const camera = new THREE.OrthographicCamera(
      -20, 20, 15, -15, 1, 1000
    );

    camera.position.z = 50;

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    mountRef.current.appendChild(renderer.domElement);

    // GRID tipo AutoCAD
    const grid = new THREE.GridHelper(50, 50);
    scene.add(grid);

    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();

    function snap(valor) {
      return Math.round(valor * 2) / 2; // precisión cada 0.5 m
    }

    function onClick(event) {
      mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const punto = raycaster.ray.origin.clone();

      punto.x = snap(punto.x);
      punto.y = snap(punto.y);

      const nuevos = [...puntos, punto];

      if (nuevos.length === 2) {
        crearElemento(nuevos[0], nuevos[1], scene);
        setObjetos(prev => [...prev, { p1: nuevos[0], p2: nuevos[1] }]);
        setPuntos([]);
      } else {
        setPuntos(nuevos);
      }
    }

    function crearElemento(p1, p2, scene) {
      const distancia = p1.distanceTo(p2);

      const altura = 3; // muro real
      const espesor = 0.15; // 15 cm

      const geometry = new THREE.BoxGeometry(distancia, espesor, altura);

      const material = new THREE.MeshStandardMaterial({
        color: tool === "muro" ? 0x999999 :
               tool === "puerta" ? 0x5a3e2b :
               0x00aaff
      });

      const mesh = new THREE.Mesh(geometry, material);

      mesh.position.set(
        (p1.x + p2.x) / 2,
        (p1.y + p2.y) / 2,
        altura / 2
      );

      mesh.rotation.z = Math.atan2(p2.y - p1.y, p2.x - p1.x);

      scene.add(mesh);

      // 👉 AGREGAR COTA
      crearCota(p1, p2, distancia, scene);
    }

    function crearCota(p1, p2, distancia, scene) {
      const loader = new THREE.FontLoader();

      loader.load(
        "https://threejs.org/examples/fonts/helvetiker_regular.typeface.json",
        function (font) {
          const textGeo = new THREE.TextGeometry(
            distancia.toFixed(2) + " m",
            {
              font: font,
              size: 0.3,
              height: 0.05,
            }
          );

          const material = new THREE.MeshBasicMaterial({ color: 0x000000 });
          const textMesh = new THREE.Mesh(textGeo, material);

          textMesh.position.set(
            (p1.x + p2.x) / 2,
            (p1.y + p2.y) / 2 + 0.5,
            0
          );

          scene.add(textMesh);
        }
      );
    }

    // LUZ REALISTA
    const light = new THREE.DirectionalLight(0xffffff, 1);
    light.position.set(10, 10, 10);
    scene.add(light);

    window.addEventListener("click", onClick);

    const animate = () => {
      requestAnimationFrame(animate);
      renderer.render(scene, camera);
    };

    animate();

    return () => {
      window.removeEventListener("click", onClick);
      mountRef.current.removeChild(renderer.domElement);
    };
  }, [tool, puntos]);

  return <div ref={mountRef}></div>;
}
