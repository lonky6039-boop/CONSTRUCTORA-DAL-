function crearViga(p1, p2, scene) {
  const largo = p1.distanceTo(p2);

  const geo = new THREE.BoxGeometry(largo, 0.2, 0.3);
  const mat = new THREE.MeshStandardMaterial({ color: 0x0000ff });

  const viga = new THREE.Mesh(geo, mat);

  viga.position.set(
    (p1.x + p2.x) / 2,
    (p1.y + p2.y) / 2,
    3.1
  );

  viga.rotation.z = Math.atan2(p2.y - p1.y, p2.x - p1.x);

  scene.add(viga);
}
